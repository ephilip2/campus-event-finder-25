<?xml version="1.0" encoding="utf-8"?>
<!--
    Launcher icon foreground - Bold Illinois block "I" letter.
    Designed to overlay the calendar background to create the app icon.
    Uses Illinois Blue (#13294b) for the letter.
    Sized to fit within the circular safe zone (66dp diameter).
    Proportions based on University of Illinois Block I design.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Block "I" shape in Illinois Blue -->
    <!-- Top serif - narrower -->
    <path
        android:fillColor="#13294b"
        android:pathData="M44,48 L64,48 L64,52 L44,52 Z" />

    <!-- Vertical bar - centered -->
    <path
        android:fillColor="#13294b"
        android:pathData="M50,52 L58,52 L58,70 L50,70 Z" />

    <!-- Bottom serif - narrower -->
    <path
        android:fillColor="#13294b"
        android:pathData="M44,70 L64,70 L64,74 L44,74 Z" />
</vector>
