<?xml version="1.0" encoding="utf-8"?>
<!--
    Launcher icon monochrome layer for themed icons (Android 13+).
    Single-color Block "I" that will be tinted by the system theme.
    Uses black (#000000) as the base color - the system will tint it appropriately.
    Same design as foreground but optimized for monochrome display.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Block "I" shape in black (will be tinted by system) -->
    <!-- Top serif - narrower -->
    <path
        android:fillColor="#000000"
        android:pathData="M44,48 L64,48 L64,52 L44,52 Z" />

    <!-- Vertical bar - centered -->
    <path
        android:fillColor="#000000"
        android:pathData="M50,52 L58,52 L58,70 L50,70 Z" />

    <!-- Bottom serif - narrower -->
    <path
        android:fillColor="#000000"
        android:pathData="M44,70 L64,70 L64,74 L44,74 Z" />
</vector>
