<?xml version="1.0" encoding="utf-8"?>
<!--
    Layout for individual event summary items in the RecyclerView list.
    Used by SummaryListAdapter to display each event in the main list.
    Shows date/time/location on first line and title on second line.
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/layout"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:clickable="true"
    android:focusable="true"
    android:padding="8dp">

    <!-- Star icon and date/time/location line -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingBottom="4dp"
        tools:ignore="UseCompoundDrawables">

        <!-- Date, time, and location combined into one line -->
        <TextView
            android:id="@+id/dateTimeLocation"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#666666"
            android:textSize="12sp" />
    </LinearLayout>

    <!-- Event title -->
    <TextView
        android:id="@+id/title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="@android:color/black"
        android:textSize="16sp" />
</LinearLayout>
